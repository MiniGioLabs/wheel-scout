# Wheel Scout — Environment Variables

# --- Provider: Alpaca (instant setup!) ---
ALPACA_API_KEY=your_alpaca_key
ALPACA_SECRET_KEY=your_alpaca_secret
ALPACA_PAPER=true

# --- Provider: Schwab (OAuth, slower setup) ---
# SCHWAB_APP_KEY=
# SCHWAB_SECRET=

# --- Discord ---
DISCORD_WEBHOOK_URL=your_webhook_url

# --- Scheduler ---
SCAN_SCHEDULE_CRON=0 8 * * 1-5
SCAN_DTE_MIN=21
SCAN_DTE_MAX=35
CANDIDATE_LIMIT=10
