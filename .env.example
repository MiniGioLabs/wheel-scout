# Wheel Scout — Environment Variables
# Copy to .env and fill in your values

# Schwab API
SCHWAB_APP_KEY=your_schwab_app_key
SCHWAB_SECRET=your_schwab_secret
SCHWAB_CALLBACK_URL=https://127.0.0.1:8182

# Discord
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook_id/your_webhook_token

# Scheduler (Eastern time)
SCAN_SCHEDULE_CRON=0 8 * * 1-5   # Mon-Fri 8:00 AM ET
SCAN_DTE_MIN=21
SCAN_DTE_MAX=35

# Optional overrides
CANDIDATE_LIMIT=10               # Max results to show in Discord
MIN_ANNUALIZED_RETURN=15         # Percentage
MIN_PREMIUM=0.30                 # Dollars per contract
